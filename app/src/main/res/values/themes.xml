<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema base de la aplicación (Material 3 - oscuro premium) -->
    <style name="Theme.AlbumTracker" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Colores de marca -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/accent</item>

        <!-- Superficies / fondos -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/error</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Tipografía global tipo Apple (Inter) -->
        <item name="fontFamily">@font/inter</item>
        <item name="android:fontFamily">@font/inter</item>
    </style>

    <!-- Tema del Splash -->
    <style name="Theme.AlbumTracker.Splash" parent="Theme.AlbumTracker">
        <item name="android:windowBackground">@drawable/bg_splash_gradient</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Estilos de texto -->
    <style name="TextAppearance.Display" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/inter_bold</item>
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/inter</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Card premium reutilizable -->
    <style name="Widget.Album.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">6dp</item>
        <item name="contentPadding">16dp</item>
        <item name="rippleColor">@color/secondary</item>
    </style>

    <!-- Botón principal -->
    <style name="Widget.Album.Button" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Indicador activo de la barra de navegación inferior -->
    <style name="BottomNavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary</item>
    </style>

    <!-- Apariencia de texto de las pestañas del álbum -->
    <style name="TabTextAppearance" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
